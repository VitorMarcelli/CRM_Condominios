# ========================================
# CRM para Condomínios — Environment Variables
# ========================================

# Database
DATABASE_URL=postgresql://crm_user:crm_password@localhost:5432/crm_condominios
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=crm_password
POSTGRES_DB=crm_condominios

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Application
APP_PORT=3001
APP_ENV=development
APP_URL=http://localhost:3001

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=CRM Condomínios

# Super Admin Seed
SEED_ADMIN_EMAIL=admin@crmcondominios.com
SEED_ADMIN_PASSWORD=Admin@123456
SEED_ADMIN_NAME=Administrador Master

# WhatsApp (Mock - future integration)
WHATSAPP_PROVIDER=mock
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_VERIFY_TOKEN=whatsapp-verify-token-change-in-production

# CORS
CORS_ORIGINS=http://localhost:3000
